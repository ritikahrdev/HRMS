# ============================================================
# HRIKA DEPLOYMENT CONFIGURATION
# Copy this file to .env and fill in your values
# Never commit .env to git — it contains secrets
# ============================================================

# Server
NODE_ENV=production
PORT=4000

# Session & Security
SESSION_SECRET=generate-a-random-string-at-least-32-chars-here-use-crypto.randomBytes(32).toString('hex')
CSRF_SECRET=another-random-32-char-string

# Admin User (created on first startup if doesn't exist)
DEFAULT_ADMIN_EMAIL=admin@digistay.ai
DEFAULT_ADMIN_PASSWORD=ChangeMe@12345

# Email Service (leave disabled if not using)
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=HR Team <your-email@gmail.com>

# Database (optional — defaults to ./data/hr.db)
# DATABASE_PATH=/absolute/path/to/hr.db

# Slack Integration (optional)
SLACK_BOT_TOKEN=xoxb-your-token
SLACK_CHANNEL_ID=C123456789

# For production: set this to enforce HTTPS
REQUIRE_HTTPS=true

# Uploads directory
UPLOAD_DIR=./data/uploads

# Session timeout (milliseconds, default 8 hours)
SESSION_MAX_AGE=28800000
